# AWS 자격증명 (ECS 배포 시에는 IAM Task Role 사용 - 키 불필요)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# Bedrock 모델
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# 기존 Bedrock 가드레일 ID (없으면 빈칸)
BEDROCK_GUARDRAIL_ID=nrkd5a2s5f8v
BEDROCK_GUARDRAIL_VERSION=DRAFT

# Kong API Key (클라이언트 인증용)
KONG_API_KEY=your-secure-api-key-here

# Guardrails 설정
BLOCK_THRESHOLD=0.8
BAN_TOPICS=
BAN_SUBSTRINGS=
MAX_TOKENS_INPUT=4096
